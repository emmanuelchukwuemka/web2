# Deployer private key (no 0x prefix)
PRIVATE_KEY=your_private_key_here

# Cronoscan API key for contract verification
CRONOSCAN_KEY=your_cronoscan_api_key_here

# Treasury wallet address (receives protocol fees + creation fees)
TREASURY_ADDRESS=0xYourTreasuryAddressHere

# VVS Finance router address on Cronos
# VERIFY THIS against current Cronos/VVS docs before deploying — do not hardcode from memory
VVS_ROUTER_ADDRESS=0xVerifyThisFromCurrentCronosDocs

# Enable gas reporter (true/false)
REPORT_GAS=false