# ── Chain ──────────────────────────────────────────────────────────────────────
RPC_URL=https://evm-t3.cronos.org
CHAIN_ID=338

# Block to start indexing from (set to the TokenFactory deploy block)
START_BLOCK=0

# ── Contract addresses (fill in after deploy) ──────────────────────────────────
TOKEN_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
NFT_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000
STAKING_ADDRESS=0x0000000000000000000000000000000000000000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=file:./dev.db

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0

# ── Indexer ────────────────────────────────────────────────────────────────────
POLL_INTERVAL_MS=5000
BLOCK_CHUNK_SIZE=2000

# ── IPFS (Pinata) ───────────────────────────────────────────────────────────────
# JWT from https://app.pinata.cloud/keys — used by the backend upload endpoint
PINATA_JWT=

# ── Admin ──────────────────────────────────────────────────────────────────────
# Secret required as "Authorization: Bearer <ADMIN_SECRET>" on /api/admin/* routes
ADMIN_SECRET=change-me-in-production